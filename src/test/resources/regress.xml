<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2" name="finalsurge" parallel="classes">
    <listeners>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.AnnotationTransformer"/>
    </listeners>
    <test name="thread1">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.RegisterTest"/>
            <class name="tests.CalendarTest"/>
            <class name="tests.UserProfileTest"/>
            <class name="tests.WorkoutReportTest"/>
        </classes>
    </test>

    <test name="thread2">
        <classes>
            <class name="tests.CustomerSupportTest"/>
            <class name="tests.WorkoutsTest"/>
            <class name="tests.DashboardTest"/>
            <class name="tests.DailyVitalsTest"/>
            <class name="tests.FeedBackTest"/>
        </classes>
    </test>
</suite>